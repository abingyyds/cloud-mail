SMTP_LISTEN_HOST=0.0.0.0
SMTP_PORT=587
SMTP_SECURE=false
SMTP_REQUIRE_TLS=true
SMTP_ALLOW_INSECURE_AUTH=false
SMTP_SERVER_NAME=smtp.example.com
SMTP_MAX_MESSAGE_SIZE=10485760
SMTP_MAX_RECIPIENTS=50

# The Worker/Open API URL. Do not put a trailing slash here.
SMMAILS_API_URL=https://mail.example.com
SMMAILS_API_TIMEOUT_MS=30000
SMTP_RELAY_TOKEN=use-the-same-secret-in-the-mail-worker

# Dynamic mode: accounts are created and managed in the product Developer page.
# The Relay authenticates them through /api/smtp/auth and sends through /api/smtp/send.

# Optional static compatibility mode. If SMTP_USERS_JSON is present, the Relay
# uses these local accounts instead of the product account management APIs.
# SMTP_USERS_JSON=[{"username":"product-a","password":"replace-me","apiKey":"smm_xxx","fromEmail":"no-reply@example.com"}]
# SMTP_USERNAME=product-a
# SMTP_PASSWORD=replace-me
# SMMAILS_API_KEY=smm_xxx
# SMTP_FROM_EMAIL=no-reply@example.com

# Required for implicit TLS on 465. For 587 STARTTLS, these are also required.
SMTP_TLS_KEY_PATH=/run/secrets/smtp.key
SMTP_TLS_CERT_PATH=/run/secrets/smtp.crt
# Railway can use inline PEM variables instead of mounted files.
# SMTP_TLS_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
# SMTP_TLS_CERT=-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----
